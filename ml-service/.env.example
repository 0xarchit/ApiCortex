# ML Service Configuration
# Copy this file to .env and fill in with actual values for local development/testing
# DO NOT commit secrets to version control

# Kafka Configuration
# Required: Comma-separated list of Kafka broker addresses
KAFKA_SERVICE_URI=localhost:9092

# TLS/SSL Configuration for Kafka (all three required if using TLS)
# Set to empty or omit if not using TLS
KAFKA_CA_CERT=
KAFKA_SERVICE_CERT=
KAFKA_SERVICE_KEY=

# Timescale Database Configuration
# Required: PostgreSQL/Timescale connection string
TIMESCALE_DATABASE=postgresql://user:password@localhost:5432/apicortex

# Model Configuration
# Optional: Path to ML model file (relative to service root)
MODEL_PATH=model/xgboost_failure_prediction.pkl

# SHAP Explainability Configuration
# Optional: Enable SHAP explainability (true/false)
ENABLE_SHAP=true

# Performance Configuration
# Optional: Threshold for alert generation (0.0-1.0)
ALERT_THRESHOLD=0.8

# Logging Configuration
# Optional: Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Kafka Topic Configuration
# Optional: Topic names (defaults shown)
KAFKA_TOPIC_RAW=telemetry.raw
KAFKA_TOPIC_ALERTS=alerts
KAFKA_GROUP_ID=apicortex-ml-inference

# Kafka Consumer Configuration
# Optional: Performance tuning parameters
KAFKA_POLL_TIMEOUT_SECONDS=1.0
KAFKA_MAX_POLL_INTERVAL_MS=300000
KAFKA_SESSION_TIMEOUT_MS=45000

# SHAP Configuration
# Optional: Number of top features to include in explainability
SHAP_TOP_K=5
